# 🔑 Auth / JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# 🤖 OpenRouter / LLM Config
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-4o

# 🎙️ Text-to-Speech (TTS)
# Falls back to OPENROUTER_API_KEY if empty, but direct OpenAI key recommended for audio
TTS_API_KEY=
TTS_BASE_URL=https://api.openai.com/v1
TTS_MODEL=tts-1
TTS_VOICE=alloy

# 💳 Stripe Payments
# Leave empty to use mock payments (development mode)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# 🅿️ PayPal Payments
# Leave empty to use mock payments (development mode)
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

# ⚡ Bitcoin / Lightning (BTCPay Server)
# Leave empty to use mock invoices (development mode)
BTCPAY_URL=
BTCPAY_API_KEY=
BTCPAY_STORE_ID=
BTCPAY_WEBHOOK_SECRET=

# 💱 Crypto Auto-Swap Exchange
# API keys for auto-converting incoming crypto payments to stablecoin (Coinbase, Kraken, etc.)
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_NAME=

# 🔔 Web Push Notifications (VAPID)
# Generate a key pair with:  python -m py_vapid --gen
# (the pywebpush package provides py_vapid). Leave empty to disable push
# delivery — the backend will skip sending and report 0, never fake a send.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# 🌐 Production / CORS
# Set to your production domain for CORS restriction
CORS_ORIGINS=*
